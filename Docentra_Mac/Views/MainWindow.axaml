<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Docentra_Mac.Views.MainWindow"
        Title="Docentra PDF Suite"
        Width="1100" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MainBackground}"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True">

    <Grid ColumnDefinitions="240, *">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}" BorderBrush="#333" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto, *, Auto">
                <!-- App Logo/Title -->
                <StackPanel Grid.Row="0" Margin="20,50,20,20">
                    <TextBlock Text="DOCENTRA" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PremiumAccentBrush}"/>
                    <TextBlock Text="PDF SUITE" FontSize="12" Opacity="0.6"/>
                </StackPanel>

                <!-- Navigation -->
                <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="10,0" x:Name="NavList" SelectionChanged="NavList_SelectionChanged">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Margin" Value="0,2"/>
                        </Style>
                    </ListBox.Styles>
                    
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource HomeRegular}" Width="18"/>
                            <TextBlock Text="{DynamicResource Nav_Dashboard}"/>
                        </StackPanel>
                    </ListBoxItem>
                    
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource MergeRegular}" Width="18"/>
                            <TextBlock Text="{DynamicResource Nav_Merge}"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource SplitRegular}" Width="18"/>
                            <TextBlock Text="{DynamicResource Nav_Split}"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource WatermarkRegular}" Width="18"/>
                            <TextBlock Text="{DynamicResource Watermark_Title}"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource LockRegular}" Width="18"/>
                            <TextBlock Text="{DynamicResource Protect_Title}"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource DeleteRegular}" Width="18"/>
                            <TextBlock Text="{DynamicResource Delete_Title}"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource PageNumRegular}" Width="18"/>
                            <TextBlock Text="{DynamicResource PageNum_Title}"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- Footer / Premium Banner -->
                <StackPanel Grid.Row="2" Margin="15" Spacing="10">
                    <Border Background="#2A2A2A" CornerRadius="10" Padding="12">
                        <Grid ColumnDefinitions="Auto, *">
                            <PathIcon Data="{StaticResource StarRegular}" Foreground="{DynamicResource PremiumAccentBrush}" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{DynamicResource Prem_TrialBanner}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="{DynamicResource Prem_DaysRemaining}" FontSize="10" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource SettingsRegular}" Width="16"/>
                            <TextBlock Text="{DynamicResource Nav_Settings}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" RowDefinitions="Auto, *">
            <!-- Header -->
            <Border Grid.Row="0" Height="50" Margin="20,30,20,0">
                <TextBlock x:Name="TxtHeader" Text="{DynamicResource Nav_Dashboard}" FontSize="24" FontWeight="SemiBold"/>
            </Border>

            <!-- Content Area -->
            <ContentControl Grid.Row="1" Margin="20" x:Name="MainContent">
                <ScrollViewer>
                    <StackPanel Spacing="20">
                        <!-- Example Dashboard Cards -->
                        <WrapPanel x:Name="DashboardPanel">
                            <Border Width="200" Height="150" Background="#1E1E1E" CornerRadius="12" Margin="0,0,20,20" Padding="20">
                                <StackPanel VerticalAlignment="Center" Spacing="10">
                                    <PathIcon Data="{StaticResource MergeRegular}" Width="32" Height="32" Foreground="{DynamicResource PremiumAccentBrush}"/>
                                    <TextBlock Text="{DynamicResource Nav_Merge}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- More cards will be added here -->
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </ContentControl>
        </Grid>
    </Grid>
    
    <Window.Resources>
        <!-- Icons from FluentUI (approximate paths for demonstration) -->
        <StreamGeometry x:Key="HomeRegular">M12 2.09961L2 9.09961V20.0996C2 21.2042 2.89543 22.0996 4 22.0996H20C21.1046 22.0996 22 21.2042 22 20.0996V9.09961L12 2.09961ZM20 20.0996H4V10.244L12 4.64402L20 10.244V20.0996Z</StreamGeometry>
        <StreamGeometry x:Key="MergeRegular">M4 4C2.89543 4 2 4.89543 2 6V18C2 19.1046 2.89543 20 4 20H8V18H4V6H8V4H4ZM16 4C17.1046 4 18 4.89543 18 6V18C18 19.1046 17.1046 20 16 20H12V18H16V6H12V4H16ZM10 7V17L14 12L10 7Z</StreamGeometry>
        <StreamGeometry x:Key="SplitRegular">M3 5C3 3.89543 3.89543 3 5 3H19C20.1046 3 21 3.89543 21 5V19C21 20.1046 20.1046 21 19 21H5C3.89543 21 3 20.1046 3 19V5ZM5 5V19H11V5H5ZM13 19H19V5H13V19Z</StreamGeometry>
        <StreamGeometry x:Key="SettingsRegular">M12 15C13.6569 15 15 13.6569 15 12C15 10.3431 13.6569 9 12 9C10.3431 9 9 10.3431 9 12C9 13.6569 10.3431 15 12 15Z</StreamGeometry>
        <StreamGeometry x:Key="StarRegular">M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z</StreamGeometry>
    </Window.Resources>
</Window>
