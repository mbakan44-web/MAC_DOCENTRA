<Application x:Class="PromtAiPdfPro.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="MainView.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Style: All Pages must be transparent to see window color, and enforce dynamic text color -->
            <Style TargetType="Page">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>
            
            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <!-- Premium Fluent UI Styles -->
            <LinearGradientBrush x:Key="PremiumGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#20FFFFFF" Offset="0.0"/>
                <GradientStop Color="#0AFFFFFF" Offset="1.0"/>
            </LinearGradientBrush>

            <SolidColorBrush x:Key="GlassBackgroundBrush" Color="#1C1C1C" Opacity="0.6"/>
            <SolidColorBrush x:Key="PremiumAccentBrush" Color="#0078D4"/>
            
            <Style x:Key="PremiumCardStyle" TargetType="ui:CardAction">
                <Setter Property="Background" Value="{DynamicResource PremiumGradientBrush}"/>
                <Setter Property="BorderBrush" Value="#30FFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="24"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#25FFFFFF"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource PremiumAccentBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="PremiumHeaderTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="36"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>

            <Style x:Key="PremiumHeaderSub" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Margin" Value="0,0,0,32"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>


