<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <!-- General -->
    <system:String x:Key="AppTitle">DOCENTRA PDF &amp; DOCUMENT EDITOR</system:String>
    <system:String x:Key="Nav_Dashboard">Centre de Contrôle</system:String>
    <system:String x:Key="Nav_Merge">Fusionner PDF</system:String>
    <system:String x:Key="Nav_Split">Diviser PDF</system:String>
    <system:String x:Key="Nav_Convert">Convertir</system:String>
    <system:String x:Key="Nav_OfficeConvert">Convertisseur Office</system:String>
    <system:String x:Key="Nav_PasswordSecurity">Sécurité et Mot de Passe</system:String>
    <system:String x:Key="Nav_Watermark">Filigrane et Logo</system:String>
    <system:String x:Key="Nav_Settings">Paramètres</system:String>

    <!-- Premium & License -->
    <system:String x:Key="Prem_LockReason_Discount">Période d'essai de 7 jours expirée. Certaines pages sont réservées au Premium.</system:String>
    <system:String x:Key="Prem_LockReason_Restricted">Essai de 14 jours expiré. Certaines pages sont fermées et la limite de 5 pages est active.</system:String>
    <system:String x:Key="Prem_Status_Full">Toutes les fonctionnalités ouvertes (Période d'essai)</system:String>
    <system:String x:Key="Prem_Status_Discount">Accès limité (Opportunité de réduction de 40 %)</system:String>
    <system:String x:Key="Prem_Status_Restricted">Version gratuite limitée</system:String>
    <system:String x:Key="Prem_PurchaseRequired_Msg">Veuillez acheter une licence pour utiliser cet écran.</system:String>
    <system:String x:Key="Prem_PurchaseRequired_Title">Fonctionnalité Premium</system:String>
    <system:String x:Key="Prem_LimitedMode">Mode limité</system:String>
    <system:String x:Key="Prem_RestrictedMode">Mode restreint</system:String>
    <system:String x:Key="Prem_SomePagesLocked">Certaines pages verrouillées</system:String>
    <system:String x:Key="Prem_PageLimitActive">Limite de 5 pages active</system:String>
    <system:String x:Key="Prem_GoToPremium">Passer à Premium</system:String>
    <system:String x:Key="Prem_Close">Fermer</system:String>

    <!-- Sign -->
    <system:String x:Key="Sign_Title">Signature de PDF</system:String>
    <system:String x:Key="Sign_SelectPdf">Sélectionner un PDF</system:String>
    <system:String x:Key="Sign_Method">Méthode de signature</system:String>
    <system:String x:Key="Sign_Draw">Écriture manuscrite (Dessiner)</system:String>
    <system:String x:Key="Sign_Upload">Charger une image</system:String>
    <system:String x:Key="Sign_Clear">Effacer</system:String>
    <system:String x:Key="Sign_Position">Position</system:String>
    <system:String x:Key="Sign_Size">Taille</system:String>
    <system:String x:Key="Sign_Opacity">Opacité</system:String>
    <system:String x:Key="Sign_ApplyTo">Appliquer à</system:String>
    <system:String x:Key="Sign_AllPages">Toutes les pages</system:String>
    <system:String x:Key="Sign_CurrentPage">Cette page uniquement</system:String>
    <system:String x:Key="Sign_CustomPages">Pages personnalisées</system:String>
    <system:String x:Key="Sign_Process">Signer et enregistrer</system:String>
    <system:String x:Key="Sign_NoFile">Veuillez d'abord sélectionner un PDF.</system:String>
    <system:String x:Key="Sign_NoSignature">Veuillez créer ou charger une signature.</system:String>
    <system:String x:Key="Sign_Success">Fichier signé avec succès.</system:String>
    <system:String x:Key="Sign_SuccessWithOpen">Fichier signé avec succès. Voulez-vous l'ouvrir ?</system:String>

    <!-- Dashboard -->
    <system:String x:Key="Dash_Welcome">Bienvenue !</system:String>
    <system:String x:Key="Dash_Desc">Votre guichet unique pour tous vos besoins PDF.</system:String>
    <system:String x:Key="Dash_MergeTitle">Fusionner</system:String>
    <system:String x:Key="Dash_MergeSub">Combinez plusieurs fichiers PDF en un seul.</system:String>
    <system:String x:Key="Dash_SplitTitle">Diviser</system:String>
    <system:String x:Key="Dash_SplitSub">Enregistrez les pages comme fichiers PDF séparés.</system:String>
    <system:String x:Key="Dash_WordTitle">Vers Word</system:String>
    <system:String x:Key="Dash_WordSub">Exportez des fichiers PDF au format Word.</system:String>
    <system:String x:Key="Dash_ImgTitle">Image vers PDF</system:String>
    <system:String x:Key="Dash_ImgSub">Convertissez vos images au format PDF.</system:String>
    <system:String x:Key="Dash_OfficeTitle">Office vers PDF</system:String>
    <system:String x:Key="Dash_OfficeSub">Convertissez Word, Excel et PowerPoint en PDF.</system:String>
    <system:String x:Key="Dash_ProtectTitle">Chiffrer</system:String>
    <system:String x:Key="Dash_ProtectSub">Protégez vos fichiers PDF par chiffrement.</system:String>
    <system:String x:Key="Dash_UnlockTitle">Supprimer Mot de Passe</system:String>
    <system:String x:Key="Dash_UnlockSub">Supprimez les mots de passe existants des PDF.</system:String>
    <system:String x:Key="Dash_TextWatermarkTitle">Filigrane de Texte</system:String>
    <system:String x:Key="Dash_TextWatermarkSub">Ajoutez un filigrane de texte interactif.</system:String>
    <system:String x:Key="Dash_LogoWatermarkTitle">Ajouter Logo</system:String>
    <system:String x:Key="Dash_LogoWatermarkSub">Placez un logo transparent dans vos fichiers.</system:String>
    <system:String x:Key="Dash_DragDrop">Glissez les fichiers ici</system:String>
    <system:String x:Key="Dash_DragDropSub">Déposez les fichiers PDF pour démarrer le processus.</system:String>

    <!-- Merge Tool -->
    <system:String x:Key="Merge_Title">Fusionner PDF</system:String>
    <system:String x:Key="Merge_Desc">Ajoutez vos fichiers PDF et fusionnez-les dans l'ordre de votre choix.</system:String>
    <system:String x:Key="Merge_AddFile">Ajouter Fichier</system:String>
    <system:String x:Key="Merge_ClearList">Vider Liste</system:String>
    <system:String x:Key="Merge_MergeBtn">Fusionner et Enregistrer</system:String>
    <system:String x:Key="Merge_EmptyStateDesc">Déposez les fichiers PDF ici ou cliquez sur le bouton 'Ajouter fichier'</system:String>
    <system:String x:Key="Merge_DefaultFileName">fusionné.pdf</system:String>
    <system:String x:Key="Merge_SuccessWithOpen">Fichiers fusionnés avec succès. Voulez-vous l'ouvrir ?</system:String>
    
    <!-- Split Tool -->
    <system:String x:Key="Split_Title">Diviser PDF</system:String>
    <system:String x:Key="Split_Desc">Sélectionnez le fichier PDF que vous souhaitez diviser.</system:String>
    <system:String x:Key="Split_Browse">Sélectionner Fichier</system:String>
    <system:String x:Key="Split_Options">Options de Division</system:String>
    <system:String x:Key="Split_OptSeparate">Convertir toutes les pages en PDF séparés</system:String>
    <system:String x:Key="Split_OptDesc">Exporte chaque page du fichier PDF sélectionné comme un fichier PDF séparé.</system:String>
    <system:String x:Key="Split_SplitBtn">Diviser en Parties</system:String>
    <system:String x:Key="Split_SuccessWithOpen">PDF divisé avec succès. Voulez-vous ouvrir le dossier ?</system:String>

    <!-- Convert Tool -->
    <system:String x:Key="Conv_Title">Outils de Conversion</system:String>
    <system:String x:Key="Conv_Desc">Gérez vos opérations de conversion PDF d'ici.</system:String>
    <system:String x:Key="Conv_ImgToPdf">Image vers PDF</system:String>
    <system:String x:Key="Conv_ImgToPdfDesc">Convertissez vos fichiers JPG ou PNG en PDF.</system:String>
    <system:String x:Key="Conv_OfficeToPdf">Office vers PDF</system:String>
    <system:String x:Key="Conv_OfficeToPdfDesc">Convertissez Word (.docx), Excel (.xlsx) ou PowerPoint (.pptx) en PDF.</system:String>
    <system:String x:Key="Conv_PdfToWord">PDF vers Word</system:String>
    <system:String x:Key="Conv_PdfToWordDesc">Convertissez des fichiers PDF au format Word (.docx) éditable.</system:String>
    <system:String x:Key="Conv_PdfToImg">PDF vers Image</system:String>
    <system:String x:Key="Conv_PdfToImgDesc">Séparez les pages PDF en fichiers image (PNG) haute résolution.</system:String>
    <system:String x:Key="Conv_Converting">Conversion en cours...</system:String>
    <system:String x:Key="Conv_Success">Conversion réussie !</system:String>
    <system:String x:Key="Conv_SuccessWithOpen">Conversion terminée avec succès. Voulez-vous ouvrir le fichier/dossier ?</system:String>
    <system:String x:Key="Conv_Error">Une erreur est survenue lors de la conversion. Assurez-vous qu'Office est installé.</system:String>
    <system:String x:Key="Conv_NoOffice">Microsoft Office non trouvé. Assurez-vous qu'il est installé.</system:String>
    <system:String x:Key="Conv_NoWord">Microsoft Word non trouvé. Assurez-vous qu'il est installé.</system:String>
    <system:String x:Key="Conv_NoExcel">Microsoft Excel non trouvé. Assurez-vous qu'il est installé.</system:String>
    <system:String x:Key="Conv_NoPowerPoint">Microsoft PowerPoint non trouvé. Assurez-vous qu'il est installé.</system:String>
    <system:String x:Key="Conv_OfficeError">Erreur lors de la conversion du document Office. Détails dans le journal.</system:String>
    <system:String x:Key="Conv_OfficeBusy">Office est peut-être occupé ou verrouillé. Veuillez fermer toutes les fenêtres Office et réessayer.</system:String>
    <system:String x:Key="Conv_CleanOffice">Nettoyer les Processus Office</system:String>
    <system:String x:Key="Conv_CleanConfirm">Toutes les fenêtres Word, Excel et PowerPoint ouvertes seront fermées. Les données non enregistrées peuvent être perdues. Voulez-vous continuer ?</system:String>
    <system:String x:Key="Conv_BtnClean">Nettoyer Office</system:String>
    <system:String x:Key="Conv_SelectImgTitle">Sélectionnez les images à convertir en PDF</system:String>
    <system:String x:Key="Conv_SelectPdfToImgTitle">Sélectionnez le fichier PDF à convertir en image</system:String>
    <system:String x:Key="Conv_SelectFolderTitle">Sélectionnez le dossier pour enregistrer les images</system:String>
    <system:String x:Key="Conv_SelectOfficeTitle">Sélectionnez le fichier Office à convertir en PDF</system:String>
    <system:String x:Key="Conv_SelectPdfToWordTitle">Sélectionnez le fichier PDF à convertir en Word</system:String>

    <!-- Office Convert -->
    <system:String x:Key="Sec_Title_OfficeConvert">Convertisseur Office</system:String>
    <system:String x:Key="Sec_Desc_OfficeConvert">Convertissez Word en Excel, ou Excel en Word.</system:String>
    <system:String x:Key="Office_WordToExcel">Word vers Excel</system:String>
    <system:String x:Key="Office_ExcelToWord">Excel vers Word</system:String>
    <system:String x:Key="Office_WordToExcelDesc">Transfère les paragraphes du document vers Excel ligne par ligne.</system:String>
    <system:String x:Key="Office_ExcelToWordDesc">Transfère les cellules Excel vers Word en texte brut.</system:String>
    <system:String x:Key="Office_PptToWord">PowerPoint vers Word</system:String>
    <system:String x:Key="Office_PptToExcel">PowerPoint vers Excel</system:String>
    <system:String x:Key="Office_PptToWordDesc">Transfère tout le texte de la présentation des diapositives vers Word.</system:String>
    <system:String x:Key="Office_PptToExcelDesc">Transfère tout le texte des diapositives vers Excel ligne par ligne.</system:String>
    <system:String x:Key="Office_SelectWordTitle">Sélectionnez le fichier Word à convertir</system:String>
    <system:String x:Key="Office_SaveExcelTitle">Enregistrer le fichier Excel</system:String>
    <system:String x:Key="Office_SelectExcelTitle">Sélectionnez le fichier Excel à convertir</system:String>
    <system:String x:Key="Office_SaveWordTitle">Enregistrer le fichier Word</system:String>
    <system:String x:Key="Office_SelectPptTitle">Sélectionnez le fichier PowerPoint à convertir</system:String>

    <!-- Settings -->
    <system:String x:Key="Sett_Title">Paramètres</system:String>
    <system:String x:Key="Sett_Language">Paramètres de Langue (Language)</system:String>
    <system:String x:Key="Sett_LanguageDesc">Sélectionnez la langue de l'application.</system:String>
    <system:String x:Key="Sett_LanguageAuto">Langue du Système (Auto)</system:String>

    <!-- Common -->
    <system:String x:Key="Common_PathPlaceholder">Aucun fichier sélectionné...</system:String>
    <system:String x:Key="Common_Save">Enregistrer</system:String>
    <system:String x:Key="Common_Cancel">Annuler</system:String>
    <system:String x:Key="Common_Apply">Appliquer</system:String>
    <system:String x:Key="Common_Back">Retour</system:String>
    <system:String x:Key="Common_PdfFilter">Fichiers PDF (*.pdf)|*.pdf</system:String>
    <system:String x:Key="Common_ImageFilter">Fichiers Image (*.jpg;*.jpeg;*.png)|*.jpg;*.jpeg;*.png</system:String>
    <system:String x:Key="Common_OfficeFilter">Documents Office (*.docx;*.doc;*.xlsx;*.xls;*.pptx;*.ppt)|*.docx;*.doc;*.xlsx;*.xls;*.pptx;*.ppt</system:String>
    <system:String x:Key="Common_WordFilter">Document Word (*.docx)|*.docx</system:String>
    <system:String x:Key="Common_ExcelFilter">Document Excel (*.xlsx)|*.xlsx</system:String>
    <system:String x:Key="Common_TxtFilter">Fichier texte (*.txt)|*.txt</system:String>
    <system:String x:Key="Common_SavePdfTitle">Enregistrer sous PDF</system:String>
    <system:String x:Key="Common_SaveWordTitle">Enregistrer sous Word</system:String>
    
    <!-- Messages -->
    <system:String x:Key="Msg_SelectAtLeastTwo">Veuillez sélectionner au moins deux fichiers PDF !</system:String>
    <system:String x:Key="Msg_MergeSuccess">Fichiers fusionnés avec succès !</system:String>
    <system:String x:Key="Msg_SettingsSaved">Paramètres enregistrés et appliqués avec succès.</system:String>
