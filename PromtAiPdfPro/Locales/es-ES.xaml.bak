    <system:String x:Key="Watermark_TextPrefix">Filigrane_</system:String>
    <system:String x:Key="Watermark_LogoPrefix">Logo_</system:String>
    <system:String x:Key="Watermark_SuccessWithOpen">Filigrane ajouté avec succès. Voulez-vous ouvrir le fichier ?</system:String>
    <system:String x:Key="Sec_RangeHelpTitle">Aide à la Plage de Pages</system:String>

    <!-- Belge Koruma ve Filigran -->
    <system:String x:Key="Sec_Title_Password">Définir &amp; Supprimer Mot de Passe</system:String>
    <system:String x:Key="Sec_Desc_Password">Définissez des mots de passe sécurisés pour vos PDF ou supprimez les existants.</system:String>
    <system:String x:Key="Sec_Title_Watermark">Outils de Filigrane et Logo</system:String>
    <system:String x:Key="Sec_Desc_Watermark">Ajoutez des filigranes de texte ou de logo de manière interactive à vos PDF.</system:String>
    <system:String x:Key="Sec_Password">1. Chiffrement PDF</system:String>
    <system:String x:Key="Sec_PasswordDesc">Sélectionnez d'abord le PDF, puis définissez le mot de passe d'ouverture.</system:String>
    <system:String x:Key="Sec_BtnProtect">Chiffrer et Enregistrer</system:String>
    <system:String x:Key="Sec_TextWatermark">1. Filigrane de Texte</system:String>
    <system:String x:Key="Sec_TextWatermarkDesc">Ajustez la taille et la position du texte de manière interactive.</system:String>
    <system:String x:Key="Sec_BtnAddText">Positionner et Ajouter</system:String>
    <system:String x:Key="Sec_ImageWatermark">2. Ajouter Logo</system:String>
    <system:String x:Key="Sec_ImageWatermarkDesc">Déterminez l'emplacement, la taille et la transparence du logo en le faisant glisser.</system:String>
    <system:String x:Key="Sec_LogoStep1">Étape 1 : Veuillez sélectionner le fichier PDF pour le logo</system:String>
    <system:String x:Key="Sec_BtnSelectLogo">Positionner et Ajouter Logo</system:String>
    <system:String x:Key="Sec_PassStep1">Étape 1 : Veuillez sélectionner le fichier PDF à chiffrer</system:String>
    <system:String x:Key="Sec_TextStep1">Étape 1 : Veuillez sélectionner le fichier PDF pour le filigrane</system:String>
    <system:String x:Key="Sec_PassStep2">Étape 2 : Définir le Mot de Passe</system:String>
    <system:String x:Key="Sec_TextStep2">Étape 2 : Texte du Filigrane</system:String>
    <system:String x:Key="Sec_Step3">Étape 3 : Sélection de Pages</system:String>
    <system:String x:Key="Sec_SelectPdf">Sélectionner Fichier PDF</system:String>
    <system:String x:Key="Sec_SelectPdfBtn">Sélectionner PDF</system:String>
    <system:String x:Key="Sec_SelectedFile">Fichier sélectionné :</system:String>
    <system:String x:Key="Sec_LogoStep2">Étape 2 : Sélectionner Logo</system:String>
    <system:String x:Key="Sec_SelectLogoBtn">Sélectionner Logo</system:String>
    <system:String x:Key="Sec_PassPlaceholder">Veuillez définir votre mot de passe...</system:String>
    <system:String x:Key="Sec_TextPlaceholder">Texte à écrire comme filigrane...</system:String>
    <system:String x:Key="Sec_LogoPlaceholder">Logo non sélectionné...</system:String>
    <system:String x:Key="Sec_RangeAll">Toutes les Pages</system:String>
    <system:String x:Key="Sec_RangeFirst">Première Page Uniquement</system:String>
    <system:String x:Key="Sec_Rotation">Angle de Rotation</system:String>
    <system:String x:Key="Sec_RangeHelp">Vous pouvez spécifier les pages à traiter sous ces formats :
• Utilisez la virgule pour des pages individuelles (ex: 1,3,5)
• Utilisez un trait d'union ou deux points pour une plage (ex: 2-5 ou 2:5)
• Des formes mixtes sont également possibles (ex: 1,3,5-8)</system:String>
    <system:String x:Key="Sec_SaveEncryptedFileName">Protégé_</system:String>

    <system:String x:Key="Sec_Help_Password">Protégez votre document PDF contre tout accès non autorisé en définissant un mot de passe sécurisé. Il sera demandé à l'ouverture.</system:String>
    <system:String x:Key="Sec_Unlock">2. Suppresseur de Mot de Passe PDF</system:String>
    <system:String x:Key="Sec_UnlockDesc">Supprimez définitivement la protection des fichiers PDF dont vous connaissez le mot de passe.</system:String>
    <system:String x:Key="Sec_UnlockStep1">Étape 1 : Veuillez sélectionner le fichier PDF pour supprimer le mot de passe</system:String>
    <system:String x:Key="Sec_UnlockStep2">Étape 2 : Entrez le mot de passe actuel du PDF</system:String>
    <system:String x:Key="Sec_UnlockPlaceholder">Entrez le mot de passe actuel ici...</system:String>
    <system:String x:Key="Sec_UnlockBtn">Supprimer le Mot de Passe</system:String>
    <system:String x:Key="Msg_UnlockSuccess">Le mot de passe PDF a été supprimé avec succès et le nouveau fichier a été enregistré !</system:String>
    <system:String x:Key="Unlock_SuccessWithOpen">Mot de passe PDF supprimé avec succès. Voulez-vous ouvrir le fichier ?</system:String>
    <system:String x:Key="Msg_UnlockError">Mot de passe incorrect ou le fichier PDF n'a pas pu être ouvert. Veuillez vérifier et réessayer.</system:String>
    <system:String x:Key="Sec_Help_Unlock">Lorsque vous sélectionnez un PDF et entrez le bon mot de passe, l'application crée une nouvelle copie 'sans mot de passe' du document.</system:String>
    <system:String x:Key="Sec_Help_TextWatermark">Identifiez le propriétaire du document avec un filigrane de texte. Via le bouton (ⓘ), vous pouvez faire glisser et redimensionner le texte dans la fenêtre interactive.</system:String>
    <system:String x:Key="Sec_Help_ImageWatermark">Ajoutez un logo ou une image comme filigrane. Dans la fenêtre interactive, vous pouvez facilement ajuster la position, la taille et la transparence du logo.</system:String>

