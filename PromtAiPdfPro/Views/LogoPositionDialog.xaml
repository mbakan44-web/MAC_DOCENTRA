<wpfui:FluentWindow x:Class="PromtAiPdfPro.Views.LogoPositionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="{DynamicResource Dialog_LogoTitle}" 
    Height="800" Width="600"
    WindowStartupLocation="CenterOwner" 
    ResizeMode="NoResize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <wpfui:TitleBar Grid.Row="0" Title="{DynamicResource Dialog_LogoTitle}" Margin="-20,-20,-20,10"/>

        <StackPanel Grid.Row="0" Margin="0,20,0,10">
            <TextBlock Text="{DynamicResource Dialog_LogoTitle}" FontSize="20" FontWeight="Bold"  HorizontalAlignment="Center"/>
            <TextBlock Text="{DynamicResource Dialog_LogoDesc}" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- A4 Sayfa Simülasyonu -->
        <Border Grid.Row="1" BorderBrush="#333" BorderThickness="1" Background="White" 
                Width="400" Height="565.7" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Canvas x:Name="PageCanvas" ClipToBounds="True" Background="Transparent">
                <Image x:Name="DraggableLogo" Width="100" Height="Auto" Cursor="Hand"
                       MouseLeftButtonDown="Logo_MouseDown" 
                       MouseMove="Logo_MouseMove" 
                       MouseLeftButtonUp="Logo_MouseUp"/>
            </Canvas>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,15,0,0">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Dialog_LogoScale}"  FontSize="12" Margin="0,0,0,5"/>
                    <Slider x:Name="SldLogoScale" Minimum="20" Maximum="300" Value="100" 
                            ValueChanged="SldLogoScale_ValueChanged" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=SldLogoScale, StringFormat='{}{0:F0}%'}" 
                            Margin="10,0,0,0" VerticalAlignment="Bottom" Width="45"/>
            </Grid>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Dialog_LogoOpacity}"  FontSize="12" Margin="0,0,0,5"/>
                    <Slider x:Name="SldOpacity" Minimum="0" Maximum="100" Value="50" 
                            ValueChanged="SldOpacity_ValueChanged" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=SldOpacity, StringFormat='{}{0:F0}%'}" 
                            Margin="10,0,0,0" VerticalAlignment="Bottom" Width="45"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <wpfui:Button Content="{DynamicResource Common_Cancel}" Click="BtnCancel_Click" Width="80" Margin="0,0,10,0"/>
                <wpfui:Button Content="{DynamicResource Common_Apply}" Appearance="Primary" Click="BtnApply_Click" Width="80"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</wpfui:FluentWindow>


