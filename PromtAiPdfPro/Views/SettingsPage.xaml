<Page x:Class="PromtAiPdfPro.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Ayarlar">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0" Click="BtnBack_Click" Margin="0,0,16,0" Padding="8" VerticalAlignment="Center" ToolTip="{DynamicResource Common_Back}">
                    <ui:SymbolIcon Symbol="ArrowLeft24"/>
                </ui:Button>
                <TextBlock Grid.Column="1" Text="{DynamicResource Sett_Title}" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            </Grid>

            <!-- 1. Dil Ayarı -->
            <ui:CardControl Margin="0,0,0,12">
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="LocalLanguage24"/>
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Sett_Language}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Sett_LanguageDesc}" FontSize="12" Opacity="0.65"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ComboBox x:Name="CboLanguage" Width="220" SelectionChanged="CboLanguage_SelectionChanged">
                    <ComboBoxItem Content="{DynamicResource Sett_LanguageAuto}" Tag="Auto"/>
                    <ComboBoxItem Content="العربية (Arabic)" Tag="ar-SA"/>
                    <ComboBoxItem Content="Deutsch (German)" Tag="de-DE"/>
                    <ComboBoxItem Content="English" Tag="en-US"/>
                    <ComboBoxItem Content="Español (Spanish)" Tag="es-ES"/>
                    <ComboBoxItem Content="Français (French)" Tag="fr-FR"/>
                    <ComboBoxItem Content="Italiano (Italian)" Tag="it-IT"/>
                    <ComboBoxItem Content="日本語 (Japanese)" Tag="ja-JP"/>
                    <ComboBoxItem Content="Русский (Russian)" Tag="ru-RU"/>
                    <ComboBoxItem Content="Türkçe (Turkish)" Tag="tr-TR"/>
                    <ComboBoxItem Content="中文 (Chinese)" Tag="zh-CN"/>
                </ComboBox>
            </ui:CardControl>

            <!-- 2. Tema Ayarı (ui:Card ile tam genişlik) -->
            <ui:Card Margin="0,0,0,12" Padding="16">
                <StackPanel>
                    <!-- Kart başlığı -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Symbol="PaintBrush24" FontSize="22" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Sett_Theme}" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="{DynamicResource Sett_ThemeDesc}" FontSize="12" Opacity="0.65" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- Tema kartları -->
                    <WrapPanel x:Name="ThemePanel" Orientation="Horizontal">

                        <!-- Karanlık -->
                        <Border x:Name="ThemeCard_Dark" Tag="Dark"
                                Width="110" Height="80" CornerRadius="10" Margin="0,0,10,10"
                                Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1C1C1C" Offset="0"/>
                                    <GradientStop Color="#3A3A3A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#0078D4" HorizontalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Theme_Dark}" Foreground="White"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,6,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Aydınlık -->
                        <Border x:Name="ThemeCard_Light" Tag="Light"
                                Width="110" Height="80" CornerRadius="10" Margin="0,0,10,10"
                                Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F8F8F8" Offset="0"/>
                                    <GradientStop Color="#DEDEDE" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#0063B1" HorizontalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Theme_Light}" Foreground="#222"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,6,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Pastel Mavi -->
                        <Border x:Name="ThemeCard_PastelBlue" Tag="PastelBlue"
                                Width="110" Height="80" CornerRadius="10" Margin="0,0,10,10"
                                Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#D7EEFF" Offset="0"/>
                                    <GradientStop Color="#A8D4F5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#157ABE" HorizontalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Theme_PastelBlue}" Foreground="#0D3A5C"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,6,0,0"
                                           HorizontalAlignment="Center" TextWrapping="Wrap"
                                           TextAlignment="Center" MaxWidth="95"/>
                            </StackPanel>
                        </Border>

                        <!-- Lavanta -->
                        <Border x:Name="ThemeCard_Lavender" Tag="Lavender"
                                Width="110" Height="80" CornerRadius="10" Margin="0,0,10,10"
                                Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#EDE7F6" Offset="0"/>
                                    <GradientStop Color="#CE93D8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#7B1FA2" HorizontalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Theme_Lavender}" Foreground="#4A0072"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,6,0,0"
                                           HorizontalAlignment="Center" TextWrapping="Wrap"
                                           TextAlignment="Center" MaxWidth="95"/>
                            </StackPanel>
                        </Border>

                        <!-- Şeftali -->
                        <Border x:Name="ThemeCard_Peach" Tag="Peach"
                                Width="110" Height="80" CornerRadius="10" Margin="0,0,10,10"
                                Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFEDE7" Offset="0"/>
                                    <GradientStop Color="#FFBBA0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#D34F1E" HorizontalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Theme_Peach}" Foreground="#7A2000"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,6,0,0"
                                           HorizontalAlignment="Center" TextWrapping="Wrap"
                                           TextAlignment="Center" MaxWidth="95"/>
                            </StackPanel>
                        </Border>

                        <!-- Nane Yeşili -->
                        <Border x:Name="ThemeCard_Mint" Tag="Mint"
                                Width="110" Height="80" CornerRadius="10" Margin="0,0,10,10"
                                Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E3F5ED" Offset="0"/>
                                    <GradientStop Color="#A5D6B9" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#1B7A52" HorizontalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Theme_Mint}" Foreground="#0A4A2A"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,6,0,0"
                                           HorizontalAlignment="Center" TextWrapping="Wrap"
                                           TextAlignment="Center" MaxWidth="95"/>
                            </StackPanel>
                        </Border>

                        <!-- Kayısı -->
                        <Border x:Name="ThemeCard_Apricot" Tag="Apricot"
                                Width="110" Height="80" CornerRadius="10" Margin="0,0,10,10"
                                Cursor="Hand" BorderThickness="3" BorderBrush="Transparent">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FDF2DA" Offset="0"/>
                                    <GradientStop Color="#FAD27A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="24" Height="24" Fill="#C67C00" HorizontalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Theme_Apricot}" Foreground="#6A3E00"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,6,0,0"
                                           HorizontalAlignment="Center" TextWrapping="Wrap"
                                           TextAlignment="Center" MaxWidth="95"/>
                            </StackPanel>
                        </Border>

                    </WrapPanel>
                </StackPanel>
            </ui:Card>

            <!-- 3. Varsayılan Klasör -->
            <ui:CardControl Margin="0,0,0,12">
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="Folder24"/>
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Sett_DefaultPath}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtDefaultPath" Text="{DynamicResource Sett_DefaultPathDesc}" FontSize="12" Opacity="0.65" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:Button Content="{DynamicResource Common_Select}" Click="BtnSelectPath_Click"/>
            </ui:CardControl>

            <!-- 4. Temizlik Modu -->
            <ui:CardControl Margin="0,0,0,12">
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="Broom24"/>
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Sett_CleanMode}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource Sett_CleanModeDesc}" FontSize="12" Opacity="0.65"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:Button Content="{DynamicResource Sett_BtnClean}" Click="BtnCleanLogs_Click" Appearance="Secondary"/>
            </ui:CardControl>

            <!-- 5. Hakkında -->
            <ui:Card Margin="0,0,0,24" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Symbol="Info24" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center" Foreground="{DynamicResource PremiumAccentBrush}"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{DynamicResource Sett_About}" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="{DynamicResource Sett_Version}" FontSize="12" Opacity="0.7"/>
                        <TextBlock Text="{DynamicResource Sett_Author}" FontSize="12" Opacity="0.7"/>
                        <TextBlock Text="{DynamicResource Sett_Website}" FontSize="12" Opacity="0.7" Cursor="Hand" Foreground="{DynamicResource PremiumAccentBrush}" MouseLeftButtonUp="BtnWebsite_Click" ToolTip="https://www.docentrapdf.com"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Kaydet Butonu -->
            <ui:Button Content="{DynamicResource Common_Save}" Click="BtnSave_Click"
                       Appearance="Primary" Padding="60,12" HorizontalAlignment="Left" Margin="0,12,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>


