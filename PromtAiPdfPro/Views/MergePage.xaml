<Page x:Class="PromtAiPdfPro.Views.MergePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="{DynamicResource Nav_Merge}"
      AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver"
      >

    <Grid Margin="48,32" Background="Transparent" AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <ui:Button Grid.Column="0" Click="BtnBack_Click" Margin="0,0,16,0" Padding="8" VerticalAlignment="Center" ToolTip="{DynamicResource Common_Back}">
                <ui:SymbolIcon Symbol="ArrowLeft24"/>
            </ui:Button>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Merge_Title}" Style="{StaticResource PremiumHeaderTitle}"/>
                <TextBlock Text="{DynamicResource Merge_Desc}" Style="{StaticResource PremiumHeaderSub}"/>
            </StackPanel>

            <ui:Button Grid.Column="2" Click="BtnAdd_Click" Appearance="Primary" Padding="24,12" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Add24" Margin="0,0,12,0" />
                    <TextBlock Text="{DynamicResource Merge_AddFile}" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
            </ui:Button>
        </Grid>

        <!-- Main Area -->
        <Grid Grid.Row="1" Margin="0,0,0,24" Background="Transparent" AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver">
            <Border Background="{DynamicResource PremiumGradientBrush}" CornerRadius="12" BorderBrush="#20FFFFFF" BorderThickness="1" AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver">
                <Grid Background="Transparent" AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver">
                    <ListBox x:Name="LstFiles" Background="Transparent" BorderThickness="0" Padding="12" AllowDrop="True" Drop="Grid_Drop" DragOver="Grid_DragOver">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Border Background="{DynamicResource GlassBackgroundBrush}" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Symbol="Document24" Margin="0,0,16,0" Foreground="{DynamicResource PremiumAccentBrush}" FontSize="20"/>
                                            <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center" FontSize="14" />
                                            <!-- Remove button could go here -->
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                        <ui:SymbolIcon Symbol="AddCircle24" FontSize="80" Foreground="{DynamicResource PremiumAccentBrush}" Margin="0,0,0,24" Opacity="0.8"/>
                        <TextBlock Text="{DynamicResource Dash_DragDrop}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Merge_EmptyStateDesc}" FontSize="15" Opacity="0.7" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Click="BtnClear_Click" Margin="0,0,16,0" Padding="20,10" Appearance="Secondary">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Delete24" Margin="0,0,8,0" />
                    <TextBlock Text="{DynamicResource Merge_ClearList}" />
                </StackPanel>
            </ui:Button>
            <ui:Button Click="BtnMerge_Click" Appearance="Primary" Padding="32,12">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowCircleRight24" Margin="0,0,12,0" />
                    <TextBlock Text="{DynamicResource Merge_MergeBtn}" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </ui:Button>
        </StackPanel>
    </Grid>
</Page>



