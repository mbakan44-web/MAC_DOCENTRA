<Page x:Class="PromtAiPdfPro.Views.CropPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:PromtAiPdfPro.Views"
      Title="{DynamicResource Nav_Crop}"
      >

    <Page.Resources>
        <local:CenterConverter x:Key="CenterConverter"/>
        
        <Style TargetType="Thumb" x:Key="HandleStyle">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PremiumAccentBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="{TemplateBinding BorderThickness}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <ui:Button Grid.Column="0" Click="BtnBack_Click" Margin="0,0,16,0" Padding="8" VerticalAlignment="Center" ToolTip="{DynamicResource Common_Back}">
                <ui:SymbolIcon Symbol="ArrowLeft24"/>
            </ui:Button>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Crop_Title}" Style="{StaticResource PremiumHeaderTitle}" FontSize="28" Margin="0"/>
                <TextBlock Text="{DynamicResource Crop_Desc}" FontSize="14" Opacity="0.6"/>
            </StackPanel>

            <ui:Button Grid.Column="2" Click="BtnBrowse_Click" Appearance="Primary" Padding="16,8">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="FolderOpen24" Margin="0,0,10,0"/>
                    <TextBlock Text="{DynamicResource Sec_SelectPdf}"/>
                </StackPanel>
            </ui:Button>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Main Preview Area -->
            <Border Grid.Column="0" Margin="0,0,24,0" CornerRadius="16" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <ScrollViewer x:Name="PreviewScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#1A1A1A">
                        <Grid x:Name="CropGrid" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid.LayoutTransform>
                                <ScaleTransform x:Name="CropGridTransform" ScaleX="1" ScaleY="1"/>
                            </Grid.LayoutTransform>
                                <!-- Image underlay -->
                                <Image x:Name="ImgPreview" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image.Effect>
                                        <DropShadowEffect BlurRadius="40" Opacity="0.5" ShadowDepth="0"/>
                                    </Image.Effect>
                                </Image>

                                <!-- Interactive Selection Canvas -->
                                <Canvas x:Name="SelectionCanvas" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- Dark Overlay -->
                                    <Path Fill="#B2000000">
                                        <Path.Data>
                                            <CombinedGeometry GeometryCombineMode="Exclude">
                                                <CombinedGeometry.Geometry1>
                                                    <RectangleGeometry x:Name="OverlayFullRect"/>
                                                </CombinedGeometry.Geometry1>
                                                <CombinedGeometry.Geometry2>
                                                    <RectangleGeometry x:Name="OverlaySelectionRect"/>
                                                </CombinedGeometry.Geometry2>
                                            </CombinedGeometry>
                                        </Path.Data>
                                    </Path>

                                    <!-- Selection Box with Handles -->
                                    <Canvas x:Name="SelectionBox" Width="200" Height="200">
                                        <!-- Border -->
                                        <Rectangle x:Name="SelectionBorder" Width="{Binding Width, ElementName=SelectionBox}" Height="{Binding Height, ElementName=SelectionBox}" Stroke="{DynamicResource PremiumAccentBrush}" StrokeThickness="2" StrokeDashArray="4 2">
                                            <Rectangle.Fill>
                                                <SolidColorBrush Color="Transparent"/>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        
                                        <!-- Invisible drag area for the whole box -->
                                        <Thumb x:Name="MoveThumb" Width="{Binding Width, ElementName=SelectionBox}" Height="{Binding Height, ElementName=SelectionBox}" Opacity="0" Cursor="SizeAll" DragDelta="MoveThumb_DragDelta"/>

                                        <!-- Corners -->
                                        <Thumb x:Name="ResizeNW" Style="{StaticResource HandleStyle}" Canvas.Left="-6" Canvas.Top="-6" Cursor="SizeNWSE" DragDelta="ResizeHandle_DragDelta" Tag="NW"/>
                                        <Thumb x:Name="ResizeNE" Style="{StaticResource HandleStyle}" Canvas.Right="-6" Canvas.Top="-6" Cursor="SizeNESW" DragDelta="ResizeHandle_DragDelta" Tag="NE"/>
                                        <Thumb x:Name="ResizeSW" Style="{StaticResource HandleStyle}" Canvas.Left="-6" Canvas.Bottom="-6" Cursor="SizeNESW" DragDelta="ResizeHandle_DragDelta" Tag="SW"/>
                                        <Thumb x:Name="ResizeSE" Style="{StaticResource HandleStyle}" Canvas.Right="-6" Canvas.Bottom="-6" Cursor="SizeNWSE" DragDelta="ResizeHandle_DragDelta" Tag="SE"/>

                                        <!-- Mid-points -->
                                        <Thumb x:Name="ResizeN" Style="{StaticResource HandleStyle}" Canvas.Left="{Binding Width, ElementName=SelectionBox, Converter={StaticResource CenterConverter}}" Canvas.Top="-6" Cursor="SizeNS" DragDelta="ResizeHandle_DragDelta" Tag="N"/>
                                        <Thumb x:Name="ResizeS" Style="{StaticResource HandleStyle}" Canvas.Left="{Binding Width, ElementName=SelectionBox, Converter={StaticResource CenterConverter}}" Canvas.Bottom="-6" Cursor="SizeNS" DragDelta="ResizeHandle_DragDelta" Tag="S"/>
                                        <Thumb x:Name="ResizeW" Style="{StaticResource HandleStyle}" Canvas.Top="{Binding Height, ElementName=SelectionBox, Converter={StaticResource CenterConverter}}" Canvas.Left="-6" Cursor="SizeWE" DragDelta="ResizeHandle_DragDelta" Tag="W"/>
                                        <Thumb x:Name="ResizeE" Style="{StaticResource HandleStyle}" Canvas.Top="{Binding Height, ElementName=SelectionBox, Converter={StaticResource CenterConverter}}" Canvas.Right="-6" Cursor="SizeWE" DragDelta="ResizeHandle_DragDelta" Tag="E"/>
                                    </Canvas>
                                </Canvas>
                            </Grid>
                    </ScrollViewer>
                    
                    <!-- Zoom and Page Controls Overlay -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,32">
                        <ui:Card Padding="6" Background="#CC1E1E1E">
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Icon="Subtract24" Click="BtnZoomOut_Click" Appearance="Secondary" Padding="8"/>
                                <TextBlock x:Name="TxtZoom" Text="100%" VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold" Width="50" TextAlignment="Center"/>
                                <ui:Button Icon="Add24" Click="BtnZoomIn_Click" Appearance="Secondary" Padding="8"/>
                                
                                <Separator Margin="12,4" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                                
                                <ui:Button Icon="ArrowLeft24" Click="BtnPrevPage_Click" Appearance="Secondary" Padding="8"/>
                                <TextBlock x:Name="TxtPageInfo" Text="1 / 1" VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold" MinWidth="60" TextAlignment="Center"/>
                                <ui:Button Icon="ArrowRight24" Click="BtnNextPage_Click" Appearance="Secondary" Padding="8"/>
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Sidebar -->
            <Grid Grid.Column="1">
                <ui:Card Padding="24" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Crop_Settings}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <ui:Card Padding="16" Margin="0,0,0,20" Background="{DynamicResource ControlFillColorSecondaryBrush}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Crop_AreaInfo}" FontSize="13" Opacity="0.8" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                <CheckBox x:Name="ChkApplyToAll" Content="{DynamicResource Crop_ApplyAll}" IsChecked="True" FontSize="14"/>
                            </StackPanel>
                        </ui:Card>
                        
                        <ui:Button x:Name="BtnApplyCrop" Click="BtnCrop_Click" Appearance="Primary" Padding="0,20" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Crop24" Margin="0,0,12,0" FontSize="24"/>
                                <TextBlock Text="{DynamicResource Crop_Btn}" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </ui:Button>
                        
                        <TextBlock x:Name="TxtFileName" Text="" FontSize="12" Opacity="0.5" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    </StackPanel>
                </ui:Card>
            </Grid>
        </Grid>
    </Grid>
</Page>
