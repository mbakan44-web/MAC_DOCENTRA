<Page x:Class="PromtAiPdfPro.Views.PremiumPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      Title="Premium Activation"
      >

    <Grid Margin="48">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.8*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol Taraf: Aktivasyon Formu -->
        <StackPanel Grid.Column="0" Margin="0,0,48,0">
            <TextBlock Text="{DynamicResource Prem_Title}" FontSize="32" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="{DynamicResource Prem_Subtitle}" FontSize="16" Opacity="0.7" Margin="0,0,0,24" TextWrapping="Wrap"/>

            <ui:InfoBar x:Name="PremiumStatusInfoBar"
                        Title="{DynamicResource Prem_Licensed}"
                        Message="{DynamicResource Prem_ThankYou}"
                        Severity="Success"
                        IsOpen="False"
                        IsClosable="False"
                        Margin="0,0,0,24" />
            
            <!-- Etsy Activation Help Bar -->
            <ui:Button x:Name="BtnHowToActivate" 
                       Appearance="Secondary" 
                       HorizontalAlignment="Stretch" 
                       Margin="0,0,0,16" 
                       Padding="16,12"
                       Click="BtnHowToActivate_Click">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="QuestionCircle24" Margin="0,0,12,0" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Prem_HowToActivate_Title}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{DynamicResource Prem_HowToActivate_Sub}" FontSize="12" Opacity="0.7"/>
                    </StackPanel>
                </StackPanel>
            </ui:Button>

            <ui:Card Padding="24" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Prem_HwidLabel}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="TxtHwid" IsReadOnly="True" Text="Fetching ID..." VerticalAlignment="Center"/>
                        <ui:Button Grid.Column="1" Margin="8,0,0,0" Click="BtnCopyHwid_Click">
                            <ui:SymbolIcon Symbol="Copy24"/>
                        </ui:Button>
                    </Grid>
                    <TextBlock Text="{DynamicResource Prem_HwidDesc}" FontSize="12" Opacity="0.6" Margin="0,4,0,0"/>
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="24">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Prem_KeyLabel}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ui:TextBox x:Name="TxtLicenseKey" PlaceholderText="XXXX-XXXX-XXXX-XXXX" Margin="0,0,0,16"/>
                    <ui:Button x:Name="BtnActivate" Content="{DynamicResource Prem_BtnActivate}" Appearance="Primary" HorizontalAlignment="Stretch" Padding="0,12" Click="BtnActivate_Click"/>
                </StackPanel>
            </ui:Card>

            <StackPanel Margin="0,32,0,0">
                <TextBlock Text="{DynamicResource Prem_WhyGoPremium}" FontWeight="Bold" FontSize="18" Margin="0,0,0,12"/>
                <ui:InfoBar Title="{DynamicResource Prem_Feat1_Title}" Message="{DynamicResource Prem_Feat1_Desc}" Severity="Informational" IsOpen="True" Margin="0,0,0,8" IsClosable="False"/>
                <ui:InfoBar Title="{DynamicResource Prem_Feat2_Title}" Message="{DynamicResource Prem_Feat2_Desc}" Severity="Informational" IsOpen="True" Margin="0,0,0,8" IsClosable="False"/>
                <ui:InfoBar Title="{DynamicResource Prem_Feat3_Title}" Message="{DynamicResource Prem_Feat3_Desc}" Severity="Informational" IsOpen="True" IsClosable="False"/>
            </StackPanel>
        </StackPanel>

        <!-- Sağ Taraf: Fiyatlandırma Paneli -->
        <ui:Card Grid.Column="1" VerticalAlignment="Stretch" Padding="24" Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <StackPanel x:Name="PricingStack" Visibility="Visible">
                    <TextBlock x:Name="TxtPricingTitle" Text="{DynamicResource Prem_Pricing_Title}" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    
                    <Grid MinHeight="500">
                        <ui:ProgressRing x:Name="PricingLoading" IsIndeterminate="True" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <wv2:WebView2 x:Name="WvPricing" 
                                      MinHeight="600" 
                                      Visibility="Hidden"
                                      NavigationCompleted="WvPricing_NavigationCompleted"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </ui:Card>
    </Grid>
</Page>
