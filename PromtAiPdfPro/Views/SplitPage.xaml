<Page x:Class="PromtAiPdfPro.Views.SplitPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="{DynamicResource Nav_Split}"
      >
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header (Fixed at top) -->
        <Grid Grid.Row="0" Margin="48,32,48,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Click="BtnBack_Click" Margin="0,0,16,0" Padding="8" VerticalAlignment="Center" ToolTip="{DynamicResource Common_Back}">
                <ui:SymbolIcon Symbol="ArrowLeft24"/>
            </ui:Button>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Split_Title}" Style="{StaticResource PremiumHeaderTitle}"/>
                <TextBlock Text="{DynamicResource Split_Desc}" FontSize="16" Opacity="0.7"/>
            </StackPanel>
        </Grid>

        <!-- Content Area (Scrollable) -->
        <ScrollViewer Grid.Row="1" Margin="0,16,0,0" Padding="48,0,48,32" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                
                <!-- Main Selection Card -->
                <ui:CardAction Margin="0,0,0,24" Padding="32" Click="BtnBrowse_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <ui:SymbolIcon Grid.Column="0" Symbol="DocumentSearch24" FontSize="48" Foreground="{DynamicResource PremiumAccentBrush}" Margin="0,0,24,0"/>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Sec_SelectPdf}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtSourceFile" Text="{DynamicResource Common_PathPlaceholder}" FontSize="14" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        
                        <ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight24" FontSize="24" Foreground="Gray" VerticalAlignment="Center"/>
                    </Grid>
                </ui:CardAction>
                
                <!-- PDF Preview Area -->
                <Border x:Name="PreviewContainer" Visibility="Collapsed" Margin="0,0,0,24" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" Height="220">
                    <Grid>
                        <Image x:Name="ImgPreview" Margin="12" Stretch="Uniform" Effect="{DynamicResource DropShadowEffect}"/>
                        <ui:SymbolIcon Symbol="Eye24" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="16" Opacity="0.3" FontSize="24"/>
                    </Grid>
                </Border>

                <!-- Options -->
                <ui:CardControl Header="{DynamicResource Split_Options}" Margin="0,0,0,24">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="Settings24" FontSize="24" Foreground="#FFD700"/>
                    </ui:CardControl.Icon>
                    <StackPanel>
                        <RadioButton x:Name="RbSplitAll" Content="{DynamicResource Split_OptSeparate}" IsChecked="True" GroupName="SplitMode" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Split_OptDesc}" Margin="28,0,0,16" Opacity="0.7" FontSize="14" TextWrapping="Wrap"/>
                        
                        <RadioButton x:Name="RbSplitRange" Content="{DynamicResource Split_OptRange}" GroupName="SplitMode" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                        <StackPanel Margin="28,0,0,0">
                            <ui:TextBox x:Name="TxtPageRange" PlaceholderText="1, 3, 5:8" Margin="0,0,0,8" Visibility="{Binding IsChecked, ElementName=RbSplitRange, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{DynamicResource Split_RangeHint}" Opacity="0.7" FontSize="14" TextWrapping="Wrap" Visibility="{Binding IsChecked, ElementName=RbSplitRange, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </ui:CardControl>

                <!-- Action Button -->
                <ui:Button Click="BtnSplit_Click" Appearance="Primary" Padding="48,16" HorizontalAlignment="Right" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Subtract24" Margin="0,0,12,0" FontSize="20"/>
                        <TextBlock Text="{DynamicResource Split_SplitBtn}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



