<Page x:Class="PromtAiPdfPro.Views.SignPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Sign PDF">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <ui:Button Grid.Column="0" Click="BtnBack_Click" Margin="0,0,16,0" Padding="8" VerticalAlignment="Center" ToolTip="{DynamicResource Common_Back}">
                <ui:SymbolIcon Symbol="ArrowLeft24"/>
            </ui:Button>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Sign_Title}" Style="{StaticResource PremiumHeaderTitle}" FontSize="28"/>
                <TextBlock Text="{DynamicResource Dash_SignSub}" FontSize="15" Margin="0,0,0,16" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Controls -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,24,0">
                <StackPanel>
                    <!-- Step 1: Select PDF -->
                    <ui:CardAction Margin="0,0,0,16" Padding="16" Click="BtnSelectPdf_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="DocumentSearch24" Margin="0,0,16,0" FontSize="24" Foreground="{DynamicResource PremiumAccentBrush}"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{DynamicResource Sign_SelectPdf}" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Name="TxtSelectedPdf" Text="{DynamicResource Common_PathPlaceholder}" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardAction>

                    <!-- Step 2: Signature Method -->
                    <ui:Card Margin="0,0,0,16" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Sign_Method}" FontWeight="Bold" Margin="0,0,0,12"/>
                            <RadioButton x:Name="RbDraw" Content="{DynamicResource Sign_Draw}" IsChecked="True" Checked="RbSignMethod_Changed" Margin="0,0,0,8"/>
                            <RadioButton x:Name="RbUpload" Content="{DynamicResource Sign_Upload}" Checked="RbSignMethod_Changed"/>
                        </StackPanel>
                    </ui:Card>

                    <!-- Step 3: Drawing / Upload Area -->
                    <ui:Card Margin="0,0,0,16" Padding="12">
                        <Grid>
                            <!-- Draw Area -->
                            <StackPanel x:Name="PanelDraw" Visibility="Visible">
                                <Border Background="White" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Height="150">
                                    <InkCanvas x:Name="InkSign" Background="Transparent" StrokeCollected="InkSign_StrokeCollected"/>
                                </Border>
                                <ui:Button Content="{DynamicResource Sign_Clear}" Click="BtnClear_Click" Margin="0,8,0,0" HorizontalAlignment="Right" Appearance="Secondary"/>
                            </StackPanel>

                            <!-- Upload Area -->
                            <StackPanel x:Name="PanelUpload" Visibility="Collapsed">
                                <ui:Button x:Name="BtnSelectImage" Content="{DynamicResource Sign_Upload}" Click="BtnSelectImage_Click" HorizontalAlignment="Stretch" Padding="0,20"/>
                                <Image x:Name="ImgUploaded" Height="120" Stretch="Uniform" Margin="0,8,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>
                    </ui:Card>

                    <!-- Step 4: Size & Opacity -->
                    <ui:Card Margin="0,0,0,16" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Sign_Size}" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Slider x:Name="SliderSize" Minimum="10" Maximum="1000" Value="200" ValueChanged="Slider_ValueChanged" Margin="0,0,0,16"/>
                            
                            <TextBlock Text="{DynamicResource Sign_Opacity}" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Slider x:Name="SliderOpacity" Minimum="0.1" Maximum="1.0" Value="1.0" ValueChanged="Slider_ValueChanged"/>
                        </StackPanel>
                    </ui:Card>

                    <!-- Step 5: Application Range -->
                    <ui:Card Margin="0,0,0,24" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Sign_ApplyTo}" FontWeight="Bold" Margin="0,0,0,12"/>
                            <RadioButton x:Name="RbAll" Content="{DynamicResource Sign_AllPages}" IsChecked="True" Margin="0,0,0,8"/>
                            <RadioButton x:Name="RbCurrent" Content="{DynamicResource Sign_CurrentPage}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RbCustom" Content="{DynamicResource Sign_CustomPages}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ui:TextBox x:Name="TxtCustomRange" PlaceholderText="1,3,5:8" Width="100" IsEnabled="{Binding IsChecked, ElementName=RbCustom}"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>

                    <!-- Action Button -->
                    <ui:Button x:Name="BtnSign" Content="{DynamicResource Sign_Process}" Click="BtnSign_Click" Appearance="Primary" HorizontalAlignment="Stretch" Padding="0,16" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Right Preview -->
            <Grid Grid.Column="1">
                <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" ClipToBounds="True">
                    <Grid x:Name="GridPreviewParent">
                        <!-- PDF Image -->
                        <Image x:Name="ImgPdfPreview" Stretch="Uniform" Margin="20"/>
                        
                        <!-- Interactive Canvas Overlay -->
                        <Canvas x:Name="CanvasOverlay" Background="Transparent" IsHitTestVisible="True" MouseLeftButtonDown="CanvasOverlay_MouseLeftButtonDown" MouseMove="CanvasOverlay_MouseMove" MouseLeftButtonUp="CanvasOverlay_MouseLeftButtonUp">
                            <Border x:Name="BorderSignPreview" Background="#01FFFFFF" BorderBrush="{DynamicResource PremiumAccentBrush}" BorderThickness="1" Cursor="Hand" Visibility="Collapsed" IsHitTestVisible="True">
                                <Image x:Name="ImgSignOnPdf" Stretch="Uniform" IsHitTestVisible="False"/>
                            </Border>
                        </Canvas>
                        
                        <!-- Empty State -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" x:Name="StackPreviewEmpty">
                            <ui:SymbolIcon Symbol="DocumentSearch24" FontSize="48" Opacity="0.2"/>
                            <TextBlock Text="{DynamicResource Sign_NoFile}" Margin="0,16,0,0" Opacity="0.5"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Page Navigation for Preview -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30" x:Name="PanelPageNav" Visibility="Collapsed">
                    <ui:Button Click="BtnPrevPage_Click" Padding="8" Margin="0,0,8,0">
                        <ui:SymbolIcon Symbol="ArrowLeft24"/>
                    </ui:Button>
                    <TextBlock x:Name="TxtPageInfo" Text="Page 1 / 10" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <ui:Button Click="BtnNextPage_Click" Padding="8" Margin="8,0,0,0">
                        <ui:SymbolIcon Symbol="ArrowRight24"/>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
