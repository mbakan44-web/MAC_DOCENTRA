<Page x:Class="PromtAiPdfPro.Views.WatermarkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Watermark Tool"
      >

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <ui:Button Grid.Column="0" Click="BtnBack_Click" Margin="0,0,16,0" Padding="8" VerticalAlignment="Center" ToolTip="{DynamicResource Common_Back}">
                <ui:SymbolIcon Symbol="ArrowLeft24"/>
            </ui:Button>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Sec_Title_Watermark}" Style="{DynamicResource PremiumHeaderTitle}" FontSize="28"/>
                <TextBlock Text="{DynamicResource Sec_Desc_Watermark}" FontSize="15"  Margin="0,0,0,16" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1000" HorizontalAlignment="Left">
                
                <!-- 1. Metin Filigranı -->
                <ui:CardControl Margin="0,0,0,24">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="Text24" Foreground="{DynamicResource PremiumAccentBrush}"/>
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Sec_TextWatermark}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{DynamicResource Sec_TextWatermarkDesc}" FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>

                    <StackPanel Margin="0,12,0,0">
                        <ui:CardAction Margin="0,0,0,16" Padding="16" Click="BtnSelectPdfForText_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="DocumentSearch24" Margin="0,0,16,0" FontSize="24" Foreground="{DynamicResource PremiumAccentBrush}"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{DynamicResource Sec_TextStep1}" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock x:Name="TxtTextSelectedPdf" Text="{DynamicResource Common_PathPlaceholder}" FontSize="13" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </ui:CardAction>

                        <!-- PDF Preview Area (Text) -->
                        <Border x:Name="PreviewContainerText" Visibility="Collapsed" Margin="0,0,0,16" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" Height="180">
                            <Grid>
                                <Image x:Name="ImgPreviewText" Margin="10" Stretch="Uniform"/>
                                <ui:SymbolIcon Symbol="Eye24" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" Opacity="0.3" FontSize="18"/>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,16" x:Name="GridTextStep2" IsEnabled="False">
                            <ui:TextBox x:Name="TxtWatermarkText" PlaceholderText="{DynamicResource Sec_TextPlaceholder}" TextChanged="TxtWatermarkText_TextChanged" Icon="Text24"/>
                        </Grid>

                        <StackPanel x:Name="StackTextOptions" IsEnabled="False">
                            <Expander Header="{DynamicResource Sec_Step3}" Margin="0,0,0,16" Background="Transparent" Opacity="0.7">
                                <StackPanel Margin="12">
                                    <RadioButton x:Name="RbTextAll" Content="{DynamicResource Sec_RangeAll}" IsChecked="True" Margin="0,0,0,8"/>
                                    <RadioButton x:Name="RbTextFirst" Content="{DynamicResource Sec_RangeFirst}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="RbTextCustom" Content="{DynamicResource Sec_RangeCustom}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <ui:TextBox x:Name="TxtTextCustomRange" PlaceholderText="1,3,5:8" Width="120" IsEnabled="{Binding IsChecked, ElementName=RbTextCustom}" Margin="0,0,12,0"/>
                                        <ui:Button Padding="4" Background="Transparent" BorderThickness="0" Click="BtnRangeHelp_Click" ToolTip="{DynamicResource Sec_RangeHelp}">
                                            <ui:SymbolIcon Symbol="Info24" Foreground="{DynamicResource PremiumAccentBrush}"/>
                                        </ui:Button>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <ui:Button Click="BtnTextWatermark_Click" Appearance="Primary" Padding="32,12" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="PositionToFront24" Margin="0,0,10,0"/>
                                    <TextBlock Text="{DynamicResource Sec_BtnAddText}" FontWeight="Bold"/>
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>
                    </StackPanel>
                </ui:CardControl>

                <!-- 2. Logo Filigranı -->
                <ui:CardControl Margin="0,0,0,24">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="Image24" Foreground="#FF8C00"/>
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Sec_ImageWatermark}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{DynamicResource Sec_ImageWatermarkDesc}" FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>

                    <StackPanel Margin="0,12,0,0">
                        <ui:CardAction Margin="0,0,0,16" Padding="16" Click="BtnSelectPdfForLogo_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="DocumentSearch24" Margin="0,0,16,0" FontSize="24" Foreground="{DynamicResource PremiumAccentBrush}"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{DynamicResource Sec_LogoStep1}" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock x:Name="TxtLogoSelectedPdf" Text="{DynamicResource Common_PathPlaceholder}" FontSize="13" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </ui:CardAction>

                        <!-- PDF Preview Area (Logo) -->
                        <Border x:Name="PreviewContainerLogo" Visibility="Collapsed" Margin="0,0,0,16" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" Height="180">
                            <Grid>
                                <Image x:Name="ImgPreviewLogo" Margin="10" Stretch="Uniform"/>
                                <ui:SymbolIcon Symbol="Eye24" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" Opacity="0.3" FontSize="18"/>
                            </Grid>
                        </Border>

                        <ui:CardAction Margin="0,0,0,16" Padding="16" x:Name="GridLogoStep2" IsEnabled="False" Click="BtnSelectLogo_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="ImageSearch24" Margin="0,0,16,0" FontSize="24" Foreground="#FF8C00"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{DynamicResource Sec_LogoStep2}" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock x:Name="TxtSelectedLogoPath" Text="{DynamicResource Sec_LogoPlaceholder}" FontSize="13" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </ui:CardAction>

                        <StackPanel x:Name="StackLogoOptions" IsEnabled="False">
                            <Expander Header="{DynamicResource Sec_Step3}" Margin="0,0,0,16" Background="Transparent" Opacity="0.7">
                                <StackPanel Margin="12">
                                    <RadioButton x:Name="RbLogoAll" Content="{DynamicResource Sec_RangeAll}" IsChecked="True" Margin="0,0,0,8"/>
                                    <RadioButton x:Name="RbLogoFirst" Content="{DynamicResource Sec_RangeFirst}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="RbLogoCustom" Content="{DynamicResource Sec_RangeCustom}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <ui:TextBox x:Name="TxtLogoCustomRange" PlaceholderText="1,3,5:8" Width="120" IsEnabled="{Binding IsChecked, ElementName=RbLogoCustom}" Margin="0,0,12,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <ui:Button Click="BtnImageWatermark_Click" Appearance="Primary" Padding="32,12" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="PositionToFront24" Margin="0,0,10,0"/>
                                    <TextBlock Text="{DynamicResource Sec_BtnSelectLogo}" FontWeight="Bold"/>
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>
                    </StackPanel>
                </ui:CardControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>



