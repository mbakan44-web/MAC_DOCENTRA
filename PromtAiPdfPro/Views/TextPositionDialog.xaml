<wpfui:FluentWindow x:Class="PromtAiPdfPro.Views.TextPositionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="{DynamicResource Dialog_TextTitle}" 
    Height="800" Width="600"
    WindowStartupLocation="CenterOwner" 
    ResizeMode="NoResize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <wpfui:TitleBar Grid.Row="0" Title="{DynamicResource Dialog_TextTitle}" Margin="-20,-20,-20,10"/>

        <StackPanel Grid.Row="0" Margin="0,20,0,10">
            <TextBlock Text="{DynamicResource Dialog_TextTitle}" FontSize="20" FontWeight="Bold"  HorizontalAlignment="Center"/>
            <TextBlock Text="{DynamicResource Dialog_TextDesc}" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- A4 Sayfa Simülasyonu -->
        <Border Grid.Row="1" BorderBrush="#333" BorderThickness="1" Background="White" 
                Width="400" Height="565.7" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Canvas x:Name="PageCanvas" ClipToBounds="True" Background="Transparent">
                <TextBlock x:Name="DraggableText" Text="{DynamicResource Dialog_ExampleText}" FontSize="24" FontWeight="Bold" Foreground="Gray" 
                           Cursor="Hand"
                           MouseLeftButtonDown="Text_MouseDown" 
                           MouseMove="Text_MouseMove" 
                           MouseLeftButtonUp="Text_MouseUp">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="TextRotate" Angle="0"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Canvas>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,15,0,0">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Dialog_TextScale}"  FontSize="12" Margin="0,0,0,5"/>
                    <Slider x:Name="SldFontSize" Minimum="8" Maximum="150" Value="40" 
                            ValueChanged="SldFontSize_ValueChanged" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=SldFontSize, StringFormat='{}{0:F0} pt'}" 
                            Margin="10,0,0,0" VerticalAlignment="Bottom" Width="45"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Sec_Rotation}"  FontSize="12" Margin="0,0,0,5"/>
                    <Slider x:Name="SldRotation" Minimum="0" Maximum="360" Value="0" 
                            ValueChanged="SldRotation_ValueChanged" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=SldRotation, StringFormat='{}{0:F0}Â°'}" 
                            Margin="10,0,0,0" VerticalAlignment="Bottom" Width="45"/>
            </Grid>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Dialog_TextOpacity}"  FontSize="12" Margin="0,0,0,5"/>
                    <Slider x:Name="SldOpacity" Minimum="0" Maximum="100" Value="50" 
                            ValueChanged="SldOpacity_ValueChanged" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=SldOpacity, StringFormat='{}{0:F0}%'}" 
                            Margin="10,0,0,0" VerticalAlignment="Bottom" Width="45"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <wpfui:Button Content="{DynamicResource Common_Cancel}" Click="BtnCancel_Click" Width="80" Margin="0,0,10,0"/>
                <wpfui:Button Content="{DynamicResource Common_Apply}" Appearance="Primary" Click="BtnApply_Click" Width="80"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</wpfui:FluentWindow>


