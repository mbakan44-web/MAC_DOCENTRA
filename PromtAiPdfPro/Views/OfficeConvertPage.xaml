<Page x:Class="PromtAiPdfPro.Views.OfficeConvertPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Office Converter"
      >

    <Grid Margin="48,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Click="BtnBack_Click" Margin="0,0,16,0" Padding="8" VerticalAlignment="Center" ToolTip="{DynamicResource Common_Back}">
                <ui:SymbolIcon Symbol="ArrowLeft24"/>
            </ui:Button>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Sec_Title_OfficeConvert}" Style="{StaticResource PremiumHeaderTitle}"/>
                <TextBlock Text="{DynamicResource Sec_Desc_OfficeConvert}" FontSize="16" Opacity="0.7" Margin="0,0,0,16"/>
            </StackPanel>
        </Grid>

        <!-- Tools Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel HorizontalAlignment="Center">
                
                <!-- Word'den Excel'e -->
                <ui:CardAction Margin="0,0,24,24" Width="340" Height="260" Click="CardWordToExcel_Click" Style="{StaticResource PremiumCardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <ui:SymbolIcon Symbol="Document24" FontSize="48" Foreground="#2B579A" Margin="0,0,12,0"/>
                            <ui:SymbolIcon Symbol="ArrowRight24" FontSize="24" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ui:SymbolIcon Symbol="Grid24" FontSize="48" Foreground="#217346"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource Office_WordToExcel}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Office_WordToExcelDesc}" FontSize="13" Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ui:CardAction>

                <!-- Excel'den Word'e -->
                <ui:CardAction Margin="0,0,24,24" Width="340" Height="260" Click="CardExcelToWord_Click" Style="{StaticResource PremiumCardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <ui:SymbolIcon Symbol="Grid24" FontSize="48" Foreground="#217346" Margin="0,0,12,0"/>
                            <ui:SymbolIcon Symbol="ArrowRight24" FontSize="24" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ui:SymbolIcon Symbol="Document24" FontSize="48" Foreground="#2B579A"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource Office_ExcelToWord}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Office_ExcelToWordDesc}" FontSize="13" Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ui:CardAction>

                <!-- PPT'den Word'e -->
                <ui:CardAction Margin="0,0,24,24" Width="340" Height="260" Click="CardPptToWord_Click" Style="{StaticResource PremiumCardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <ui:SymbolIcon Symbol="ProjectionScreen24" FontSize="48" Foreground="#D24726" Margin="0,0,12,0"/>
                            <ui:SymbolIcon Symbol="ArrowRight24" FontSize="24" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ui:SymbolIcon Symbol="Document24" FontSize="48" Foreground="#2B579A"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource Office_PptToWord}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Office_PptToWordDesc}" FontSize="13" Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ui:CardAction>

                <!-- PPT'den Excel'e -->
                <ui:CardAction Margin="0,0,24,24" Width="340" Height="260" Click="CardPptToExcel_Click" Style="{StaticResource PremiumCardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <ui:SymbolIcon Symbol="ProjectionScreen24" FontSize="48" Foreground="#D24726" Margin="0,0,12,0"/>
                            <ui:SymbolIcon Symbol="ArrowRight24" FontSize="24" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ui:SymbolIcon Symbol="Grid24" FontSize="48" Foreground="#217346"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource Office_PptToExcel}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Office_PptToExcelDesc}" FontSize="13" Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ui:CardAction>

            </WrapPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border x:Name="OverlayProcessing" Grid.RowSpan="2" Background="#90000000" Visibility="Collapsed" CornerRadius="12">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="60" Height="60" Foreground="{DynamicResource PremiumAccentBrush}" Margin="0,0,0,20"/>
                <TextBlock Text="{DynamicResource Conv_Converting}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>



