<Page x:Class="PromtAiPdfPro.Views.AddPageNumbersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="{DynamicResource Nav_AddPageNumbers}"
      >

    <Page.Resources>
        <Style x:Key="PremiumApplyButton" TargetType="ui:Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#8A2BE2" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="32,18"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="#4B0082"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="48,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Click="BtnBack_Click" Margin="0,0,16,0" Padding="8" VerticalAlignment="Center" ToolTip="{DynamicResource Common_Back}">
                <ui:SymbolIcon Symbol="ArrowLeft24"/>
            </ui:Button>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource PageNum_Title}" Style="{DynamicResource PremiumHeaderTitle}"/>
                <TextBlock Text="{DynamicResource PageNum_Desc}" FontSize="16" Opacity="0.7" Margin="0,0,0,16"/>
            </StackPanel>
        </Grid>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="1100" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,32,0">
                    <!-- Main Selection Card -->
                    <ui:CardAction Margin="0,0,0,24" Padding="32" Click="BtnBrowse_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="DocumentSearch24" FontSize="48" Foreground="{DynamicResource PremiumAccentBrush}" Margin="0,0,24,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Sec_SelectPdf}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtSourceFile" Text="{DynamicResource Common_PathPlaceholder}" FontSize="14" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight24" FontSize="24" Foreground="Gray" VerticalAlignment="Center"/>
                        </Grid>
                    </ui:CardAction>

                    <!-- Settings Grouped -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Side: Range & Format -->
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <ui:Card Padding="20" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource PageNum_StepRange}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource PageNum_StartPage}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                            <ui:TextBox x:Name="TxtStartPage" Text="1" PlaceholderText="1"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="{DynamicResource PageNum_EndPage}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                            <ui:TextBox x:Name="TxtEndPage" Text="1000" PlaceholderText="1000"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <TextBlock Text="{DynamicResource PageNum_StartingValue}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                    <ui:TextBox x:Name="TxtStartingValue" Text="1" PlaceholderText="1" Margin="0,0,0,12"/>

                                    <TextBlock Text="{DynamicResource PageNum_PrefixLabel}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                    <ui:TextBox x:Name="TxtFormat" Text="" PlaceholderText="{DynamicResource PageNum_PrefixPlaceholder}" Margin="0,0,0,12"/>
                                </StackPanel>
                            </ui:Card>

                            <ui:Card Padding="20">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource PageNum_StepPosition}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <ComboBox x:Name="ComboPosition" SelectedIndex="0" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="{DynamicResource PageNum_PosBottomCenter}" Tag="BottomCenter"/>
                                        <ComboBoxItem Content="{DynamicResource PageNum_PosBottomRight}" Tag="BottomRight"/>
                                        <ComboBoxItem Content="{DynamicResource PageNum_PosBottomLeft}" Tag="BottomLeft"/>
                                        <ComboBoxItem Content="{DynamicResource PageNum_PosTopCenter}" Tag="TopCenter"/>
                                        <ComboBoxItem Content="{DynamicResource PageNum_PosTopRight}" Tag="TopRight"/>
                                        <ComboBoxItem Content="{DynamicResource PageNum_PosTopLeft}" Tag="TopLeft"/>
                                    </ComboBox>
                                </StackPanel>
                            </ui:Card>
                        </StackPanel>

                        <!-- Right Side: Style & Color -->
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <ui:Card Padding="20" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource PageNum_StepFont}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <TextBlock Text="{DynamicResource PageNum_Font}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="ComboFont" SelectedIndex="0" Margin="0,0,0,12">
                                        <ComboBoxItem Content="Arial"/>
                                        <ComboBoxItem Content="Times New Roman"/>
                                        <ComboBoxItem Content="Courier New"/>
                                        <ComboBoxItem Content="Verdana"/>
                                    </ComboBox>
                                    <TextBlock Text="{DynamicResource PageNum_Size}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                    <ui:TextBox x:Name="TxtFontSize" Text="12" PlaceholderText="12"/>
                                </StackPanel>
                            </ui:Card>

                            <ui:Card Padding="20">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource PageNum_StepColor}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <ui:TextBox x:Name="TxtColor" Text="#000000" Margin="0,0,0,12" IsReadOnly="True" HorizontalAlignment="Stretch" Visibility="Collapsed"/>
                                    
                                    <!-- Simple Color Palette -->
                                    <UniformGrid Columns="5" Margin="0,0,0,8">
                                        <ui:Button Width="30" Height="30" Background="#000000" Margin="2" Click="Color_Click" Tag="#000000" BorderThickness="0" CornerRadius="15"/>
                                        <ui:Button Width="30" Height="30" Background="#FF0000" Margin="2" Click="Color_Click" Tag="#FF0000" BorderThickness="0" CornerRadius="15"/>
                                        <ui:Button Width="30" Height="30" Background="#0000FF" Margin="2" Click="Color_Click" Tag="#0000FF" BorderThickness="0" CornerRadius="15"/>
                                        <ui:Button Width="30" Height="30" Background="#008000" Margin="2" Click="Color_Click" Tag="#008000" BorderThickness="0" CornerRadius="15"/>
                                        <ui:Button Width="30" Height="30" Background="#FFA500" Margin="2" Click="Color_Click" Tag="#FFA500" BorderThickness="0" CornerRadius="15"/>
                                        <ui:Button Width="30" Height="30" Background="#808080" Margin="2" Click="Color_Click" Tag="#808080" BorderThickness="0" CornerRadius="15"/>
                                        <ui:Button Width="30" Height="30" Background="#FFFFFF" Margin="2" Click="Color_Click" Tag="#FFFFFF" BorderThickness="1" BorderBrush="Gray" CornerRadius="15"/>
                                        <ui:Button Width="30" Height="30" Background="#FFC0CB" Margin="2" Click="Color_Click" Tag="#FFC0CB" BorderThickness="0" CornerRadius="15"/>
                                        <ui:Button Width="30" Height="30" Background="#800080" Margin="2" Click="Color_Click" Tag="#800080" BorderThickness="0" CornerRadius="15"/>
                                        <ui:Button Width="30" Height="30" Background="#FFFF00" Margin="2" Click="Color_Click" Tag="#FFFF00" BorderThickness="0" CornerRadius="15"/>
                                    </UniformGrid>
                                    
                                    <ui:Button x:Name="BtnMoreColors" Content="{DynamicResource PageNum_MoreColors}" HorizontalAlignment="Stretch" Margin="0,4,0,0" Click="BtnMoreColors_Click">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Color24"/>
                                        </ui:Button.Icon>
                                    </ui:Button>

                                    <TextBlock x:Name="TxtSelectedColor" Text="#000000" FontSize="12" HorizontalAlignment="Center" Opacity="0.7" Margin="0,8,0,0"/>
                                </StackPanel>
                            </ui:Card>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <!-- PDF Preview -->
                    <Border x:Name="PreviewContainer" Visibility="Collapsed" Margin="0,0,0,24" CornerRadius="12" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" MinHeight="300">
                        <Grid>
                            <Image x:Name="ImgPreview" Margin="12" Stretch="Uniform">
                                <Image.Effect>
                                    <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="4"/>
                                </Image.Effect>
                            </Image>
                            <ui:SymbolIcon Symbol="Eye24" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="16" Opacity="0.3" FontSize="24"/>
                        </Grid>
                    </Border>

                    <!-- Mega Premium Button -->
                    <ui:Button x:Name="BtnApply" 
                               Height="74" 
                               Margin="0,12,0,0" 
                               HorizontalAlignment="Stretch" 
                               Click="BtnApply_Click"
                               BorderThickness="0"
                               Cursor="Hand">
                        <ui:Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6366f1" Offset="0"/>
                                <GradientStop Color="#a855f7" Offset="0.5"/>
                                <GradientStop Color="#ec4899" Offset="1"/>
                            </LinearGradientBrush>
                        </ui:Button.Background>
                        <ui:Button.Content>
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Grid.Column="0" Symbol="Wand24" Foreground="White" Margin="0,0,16,0" FontSize="32" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource PageNum_MagicBtnTitle}" 
                                             FontSize="22" 
                                             FontWeight="Bold" 
                                             Foreground="White"
                                             TextAlignment="Left"/>
                                    <TextBlock Text="{DynamicResource PageNum_MagicBtnSub}" 
                                             FontSize="12" 
                                             Foreground="White" 
                                             Opacity="0.9"
                                             TextAlignment="Left"/>
                                </StackPanel>
                            </Grid>
                        </ui:Button.Content>
                        <ui:Button.Effect>
                            <DropShadowEffect BlurRadius="25" Opacity="0.5" ShadowDepth="5" Color="#A855F7"/>
                        </ui:Button.Effect>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
