<Page x:Class="PromtAiPdfPro.Views.PasswordSecurityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="{DynamicResource Nav_PasswordSecurity}"
      >

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <ui:Button Grid.Column="0" Click="BtnBack_Click" Margin="0,0,16,0" Padding="8" VerticalAlignment="Center" ToolTip="{DynamicResource Common_Back}">
                <ui:SymbolIcon Symbol="ArrowLeft24"/>
            </ui:Button>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Sec_Title_Password}" Style="{StaticResource PremiumHeaderTitle}" FontSize="28"/>
                <TextBlock Text="{DynamicResource Sec_Desc_Password}" FontSize="15"  Margin="0,0,0,16" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1000" HorizontalAlignment="Left">
                
                <!-- 1. Şifre Koruması (Lock) -->
                <ui:CardControl Margin="0,0,0,24">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="LockClosed24" FontSize="24" Foreground="#FFD700"/>
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Sec_Password}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{DynamicResource Sec_PasswordDesc}" FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>

                    <StackPanel Margin="0,12,0,0">
                        <ui:CardAction Margin="0,0,0,16" Padding="16" Click="BtnSelectPdfForPass_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="DocumentSearch24" Margin="0,0,16,0" FontSize="24" Foreground="{DynamicResource PremiumAccentBrush}"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{DynamicResource Sec_PassStep1}" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock x:Name="TxtPassSelectedPdf" Text="{DynamicResource Common_PathPlaceholder}" FontSize="13" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </ui:CardAction>

                        <Grid Margin="0,0,0,16" x:Name="GridPassStep2" IsEnabled="False">
                            <ui:PasswordBox x:Name="TxtPassword" PlaceholderText="{DynamicResource Sec_PassPlaceholder}" PasswordChanged="TxtPassword_PasswordChanged" Icon="LockClosed24" />
                        </Grid>

                        <ui:Button x:Name="BtnProtectSave" Click="BtnProtect_Click" Appearance="Primary" Padding="32,12" HorizontalAlignment="Right" IsEnabled="False">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ShieldCheckmark24" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Sec_BtnProtect}" FontWeight="Bold"/>
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </ui:CardControl>

                <!-- 2. PDF Kilidi Kaldırma (Unlock) -->
                <ui:CardControl Margin="0,0,0,24">
                    <ui:CardControl.Icon>
                        <ui:SymbolIcon Symbol="LockOpen24" FontSize="24" Foreground="#00CC66"/>
                    </ui:CardControl.Icon>
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Sec_Unlock}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{DynamicResource Sec_UnlockDesc}" FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>

                    <StackPanel Margin="0,12,0,0">
                        <ui:CardAction Margin="0,0,0,16" Padding="16" Click="BtnSelectPdfForUnlock_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="DocumentLock24" Margin="0,0,16,0" FontSize="24" Foreground="{DynamicResource PremiumAccentBrush}"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{DynamicResource Sec_UnlockStep1}" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock x:Name="TxtUnlockSelectedPdf" Text="{DynamicResource Common_PathPlaceholder}" FontSize="13" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </ui:CardAction>

                        <Grid Margin="0,0,0,16" x:Name="GridUnlockStep2" IsEnabled="False">
                            <ui:PasswordBox x:Name="TxtUnlockPassword" PlaceholderText="{DynamicResource Sec_UnlockPlaceholder}" PasswordChanged="TxtUnlockPassword_PasswordChanged" Icon="Key24" />
                        </Grid>

                        <ui:Button x:Name="BtnUnlockSave" Click="BtnUnlock_Click" Appearance="Primary" Padding="32,12" HorizontalAlignment="Right" IsEnabled="False">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ShieldDismiss24" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Sec_UnlockBtn}" FontWeight="Bold"/>
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </ui:CardControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>




